# Neon Postgres connection string
# Get this from your Neon dashboard: https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Session secret — must be at least 32 random characters
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_random_32_character_string

# API-Football key (free tier — 100 req/day)
# 1. Sign up at https://api-sports.io
# 2. Go to your dashboard and copy your API key
API_FOOTBALL_KEY=your_api_sports_key_here

# Your email address — grants access to /api/export (CSV download)
ADMIN_EMAIL=you@example.com

# Upstash Redis — used for rate limiting (free tier)
# 1. Sign up at https://upstash.com → create a Redis database
# 2. Copy the REST URL and REST token from the database's "REST API" tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Cloudflare Turnstile — CAPTCHA widget on signup (free)
# 1. Sign up at https://dash.cloudflare.com → Turnstile → add a site
# 2. Add your domain + localhost as hostnames, copy the Site Key and Secret Key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
